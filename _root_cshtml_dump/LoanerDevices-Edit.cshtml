@model LaptopTracker.Models.LoanerDevice
@using LaptopTracker.Helpers
@{
    Layout = null;
    var deviceTypes = new[] { "Lenovo", "HP", "Dell", "iPad" };
    var eonLocations = LocationList.Locations.OrderBy(l => l).ToList();
    var wicOptions = LocationList.SiteLocations.OrderBy(l => l).ToList();
    var curLoc = Model.DeviceLocation ?? "";
    var locInList = eonLocations.Contains(curLoc);
    var showOther = !locInList && curLoc != "";
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Edit Loaner Device | WIC Asset Tracker</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:"Segoe UI",Arial,sans-serif;background:#f3f2f1;color:#201f1e}
.page{min-height:100vh;padding-bottom:48px}
.topbar{display:flex;flex-wrap:wrap;align-items:center;gap:0;padding:0 28px;background:#fff;border-bottom:1px solid #e1dfdd;height:60px}
.brand{font-size:17px;font-weight:800;color:#0f6c75;text-decoration:none;margin-right:32px;white-space:nowrap}
.nav-links{display:flex;gap:2px;align-items:center;flex:1}
.nav-link{padding:8px 14px;border-radius:8px;text-decoration:none;font-size:14px;font-weight:500;color:#605e5c}
.nav-link:hover{background:#f3f2f1;color:#201f1e}
.nav-link.active{background:#e5f6f7;color:#0f6c75;font-weight:600}
.topbar-actions{display:flex;gap:10px;align-items:center}
.back{padding:9px 18px;border-radius:10px;font-size:14px;font-weight:700;text-decoration:none;border:1px solid #0f6c75;color:#0f6c75;background:transparent}
.content{padding:24px 28px 0}
.page-title{font-size:20px;font-weight:700;margin-bottom:20px}
.form-card{background:#fff;border-radius:14px;box-shadow:0 2px 8px rgba(0,0,0,0.06);padding:28px 32px;max-width:860px}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px 24px}
.form-full{grid-column:1/-1}
.fg{display:flex;flex-direction:column;gap:6px}
.fg label{font-size:13px;font-weight:600;color:#323130}
.fg input,.fg select{padding:10px 13px;border:1px solid #c8c6c4;border-radius:8px;font-size:14px;color:#201f1e;background:#fff;font-family:inherit;outline:none}
.fg input:focus,.fg select:focus{border-color:#0f6c75}
.fg .hint{font-size:12px;color:#a19f9d}
.form-actions{display:flex;gap:12px;align-items:center;padding-top:8px;flex-wrap:wrap}
.btn-submit{padding:11px 24px;background:#0f6c75;color:#fff;border:none;border-radius:10px;font-size:14px;font-weight:700;cursor:pointer}
.btn-cancel{padding:11px 20px;background:transparent;color:#605e5c;border:1px solid #c8c6c4;border-radius:10px;font-size:14px;font-weight:600;text-decoration:none;display:inline-block}
.btn-delete{padding:11px 20px;background:#c4314b;color:#fff;border:none;border-radius:10px;font-size:14px;font-weight:700;cursor:pointer;margin-left:auto}
.kid-row{display:flex;gap:8px;align-items:center}
.kid-row input{flex:1}
.btn-clear-kid{padding:9px 14px;background:transparent;color:#c4314b;border:1px solid #c4314b;border-radius:8px;font-size:13px;font-weight:700;cursor:pointer;white-space:nowrap}
.btn-clear-kid:hover{background:#c4314b;color:#fff}
</style>
</head>
<body>
<div class="page">
  <nav class="topbar">
    <a href="/Dashboard" class="brand">WIC Asset Tracker</a>
    <div class="nav-links">
      <a href="/Dashboard" class="nav-link">Dashboard</a>
      <a href="/ReturnDevices" class="nav-link">Return Devices</a>
      <a href="/WicStock" class="nav-link">WIC Stock</a>
      <a href="/LoanerDevices" class="nav-link active">Loaner Devices</a>
    </div>
    <div class="topbar-actions">
      <a href="/LoanerDevices" class="back">&larr; Back</a>
    </div>
  </nav>

  <div class="content">
    <div class="page-title">Edit Loaner Device — @Model.SerialNumber</div>
    <div class="form-card">
      <form method="post" action="/LoanerDevices/Edit/@Model.Id">
        <input type="hidden" name="Id" value="@Model.Id" />
        <input type="hidden" name="DeviceStateType" value="Loaner Device" />
        <div class="form-grid">

          <div class="fg">
            <label>Serial Number *</label>
            <input name="SerialNumber" type="text" value="@Model.SerialNumber" required />
          </div>

          <div class="fg">
            <label>Device Type</label>
            <select name="DeviceType">
              @foreach (var t in deviceTypes)
              {
                <option value="@t" @(Model.DeviceType == t ? "selected" : "")>@t</option>
              }
            </select>
          </div>

          <div class="fg">
            <label>RITM *</label>
            <input name="RITM" type="text" value="@Model.RITM" required />
          </div>

          <div class="fg">
            <label>Date</label>
            <input name="Date" type="date" value="@Model.Date.ToString("yyyy-MM-dd")" />
          </div>

          <div class="fg form-full">
            <label>Device Location</label>
            <select id="locSelect" onchange="onLocChange(this)">
              <option value="">— Select location —</option>
              @foreach (var l in eonLocations)
              {
                <option value="@l" @(locInList && curLoc == l ? "selected" : "")>@l</option>
              }
              <option value="__other__" @(showOther ? "selected" : "")>Other (type below)</option>
            </select>
            <input id="locCustom" type="text" placeholder="Type custom location…"
                   style="margin-top:6px;@(showOther ? "" : "display:none;")"
                   value="@(showOther ? curLoc : "")"
                   oninput="document.getElementById('locHidden').value=this.value" />
            <input type="hidden" id="locHidden" name="DeviceLocation" value="@curLoc" />
          </div>

          <div class="fg">
            <label>Status</label>
            <select name="Status">
              <option value="Available" @(Model.Status == LaptopTracker.Models.LoanerStatus.Available ? "selected" : "")>Available</option>
              <option value="NotAvailable" @(Model.Status == LaptopTracker.Models.LoanerStatus.NotAvailable ? "selected" : "")>Not Available</option>
            </select>
          </div>

          <div class="fg">
            <label>WIC (Office Location) <span class="hint">(optional)</span></label>
            <select name="WIC">
              <option value="">— Select WIC —</option>
              @foreach (var w in wicOptions)
              {
                <option value="@w" @(Model.WIC == w ? "selected" : "")>@w</option>
              }
            </select>
          </div>

          <div class="fg form-full">
            <label>KID (Konzern-ID) <span class="hint">(optional)</span></label>
            <div class="kid-row">
              <input id="kidInput" name="KID" type="text" value="@Model.KID" placeholder="e.g. K12345" />
              <button type="button" class="btn-clear-kid" onclick="clearKid()" title="Clear KID">&#x2715; Clear KID</button>
            </div>
          </div>

          <div class="fg">
            <label>Handed To <span class="hint">(optional)</span></label>
            <input name="KidHandedTo" type="text" value="@Model.KidHandedTo" />
          </div>

          <div class="fg">
            <label>Date Handed Over <span class="hint">(optional)</span></label>
            <input name="DateHandedOver" type="date" value="@(Model.DateHandedOver?.ToString("yyyy-MM-dd") ?? "")" />
          </div>

          <div class="form-actions form-full">
            <button type="submit" class="btn-submit">Save Changes</button>
            <a href="/LoanerDevices" class="btn-cancel">Cancel</a>
            <button type="button" class="btn-delete" onclick="deleteDevice()">Delete Device</button>
          </div>

        </div>
      </form>

      <form id="deleteForm" method="post" action="/LoanerDevices/Delete/@Model.Id" style="display:none;"></form>
    </div>
  </div>
</div>
<script>
function onLocChange(sel) {
  var c = document.getElementById('locCustom');
  var h = document.getElementById('locHidden');
  if (sel.value === '__other__') {
    c.style.display = ''; c.value = ''; h.value = ''; c.focus();
  } else {
    c.style.display = 'none'; h.value = sel.value;
  }
}
function clearKid() {
  document.getElementById('kidInput').value = '';
}
function deleteDevice() {
  if (confirm('Delete device @Html.Raw(Model.SerialNumber.Replace("'", "\\'"))? This cannot be undone.')) {
    document.getElementById('deleteForm').submit();
  }
}
</script>
</body>
</html>
