@model List<LaptopTracker.Models.ReturnDevice>
@{
    var searchQuery      = ViewData["SearchQuery"]      as string;
    var statusFilter     = ViewData["StatusFilter"]     as string;
    var locationFilter   = ViewData["LocationFilter"]   as string;
    var deviceTypeFilter = ViewData["DeviceTypeFilter"] as string;
    var hasWorkOrder = (bool)(ViewData["HasWorkOrder"] ?? false);
    var allLocations   = ViewData["Locations"]   as List<string> ?? new List<string>();
    var allDeviceTypes = ViewData["DeviceTypes"] as List<string> ?? new List<string>();
    var collectedDevices = ViewData["CollectedDevices"] as List<LaptopTracker.Models.ReturnDevice> ?? new List<LaptopTracker.Models.ReturnDevice>();
    var anyFilter = !string.IsNullOrWhiteSpace(searchQuery) || !string.IsNullOrWhiteSpace(statusFilter)
        || !string.IsNullOrWhiteSpace(locationFilter) || !string.IsNullOrWhiteSpace(deviceTypeFilter)
        || hasWorkOrder;
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Return Devices | WIC Asset Tracker</title>
<link rel="stylesheet" href="/css/theme.css" />
<script>(function(){var t=localStorage.getItem('theme')||'dark';document.documentElement.setAttribute('data-theme',t);})();</script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:"Segoe UI",Arial,sans-serif;background:var(--bg-page);color:var(--text-primary)}
.page{min-height:100vh;padding-bottom:80px}
.topbar{display:flex;flex-wrap:wrap;align-items:center;gap:0;padding:0 28px;background:var(--bg-topbar);border-bottom:1px solid var(--border);height:60px}
.brand{font-size:17px;font-weight:800;color:var(--accent);text-decoration:none;margin-right:32px;white-space:nowrap}
.nav-links{display:flex;gap:2px;align-items:center;flex:1}
.nav-link{padding:8px 14px;border-radius:8px;text-decoration:none;font-size:14px;font-weight:500;color:var(--text-secondary)}
.nav-link:hover{background:var(--bg-hover);color:var(--text-primary)}
.nav-link.active{background:var(--accent-bg);color:var(--accent);font-weight:600}
.topbar-actions{display:flex;gap:10px;align-items:center}
.btn{padding:10px 20px;border-radius:10px;font-size:14px;font-weight:700;text-decoration:none;border:none;cursor:pointer;display:inline-block}
.btn-primary{background:var(--accent);color:#fff}
.btn-danger{background:#c4314b;color:#fff}
.content{padding:20px 28px 0}
.search-form{display:flex;gap:10px;margin-bottom:8px}
.search-input{flex:1;padding:10px 14px;border:1px solid var(--border-input);border-radius:8px;font-size:14px;color:var(--text-primary);background:var(--bg-input);outline:none}
.search-input:focus{border-color:var(--accent)}
.search-btn{padding:10px 20px;background:var(--accent);color:#fff;border:none;border-radius:8px;font-size:14px;font-weight:700;cursor:pointer}
.panel{background:var(--bg-panel);border-radius:14px;box-shadow:0 2px 8px rgba(0,0,0,0.18);overflow:hidden}
.table-scroll{overflow-x:auto;width:100%}
table{width:100%;border-collapse:collapse}
thead th{text-align:left;padding:11px 14px;border-bottom:1px solid var(--border);background:var(--bg-thead);font-size:12px;font-weight:700;color:var(--text-secondary);text-transform:uppercase;letter-spacing:0.04em;white-space:nowrap}
thead th:first-child{width:36px;padding-left:12px;padding-right:4px}
tbody td{padding:10px 14px;border-bottom:1px solid var(--border);font-size:14px;color:var(--text-primary);vertical-align:middle}
tbody td:first-child{padding-left:12px;padding-right:4px}
tbody tr:last-child td{border-bottom:none}
tbody tr:hover{background:var(--bg-hover)}
.empty td{padding:48px;text-align:center;color:var(--text-muted);font-size:14px}
.link{color:var(--accent);font-weight:700;text-decoration:none}
.badge{display:inline-flex;align-items:center;padding:4px 10px;border-radius:999px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;white-space:nowrap}
.b-pending{background:#fff4d6;color:#755000}
.b-pickedup{background:#d8f6e8;color:#0b633d}
.b-intransit{background:#ede9fe;color:#5b21b6}
.b-inwic{background:#f3f2f1;color:#323130}
.b-yes{background:#d8f6e8;color:#0b633d}
.b-no{background:#fde2c7;color:#8a4f00}
.muted{color:var(--text-muted);font-size:13px}
.tabs{display:flex;gap:4px;margin-bottom:16px;border-bottom:2px solid var(--border)}
.tab-btn{padding:10px 20px;border:none;background:transparent;font-size:14px;font-weight:600;color:var(--text-secondary);cursor:pointer;border-bottom:3px solid transparent;margin-bottom:-2px;border-radius:8px 8px 0 0}
.tab-btn:hover{background:var(--bg-hover);color:var(--text-primary)}
.tab-btn.active{color:var(--accent);border-bottom-color:var(--accent);background:var(--accent-bg)}
.tab-badge{display:inline-flex;align-items:center;justify-content:center;min-width:20px;height:20px;border-radius:50%;font-size:11px;font-weight:700;margin-left:6px;background:var(--bg-thead);color:var(--text-secondary)}
.tab-btn.active .tab-badge{background:var(--accent);color:#fff}
.tab-panel{display:none}.tab-panel.active{display:block}
.tabs{display:flex;gap:4px;margin-bottom:16px;border-bottom:2px solid var(--border);padding-bottom:0;align-items:center}
.tab-btn{padding:10px 20px;border:none;background:transparent;font-size:14px;font-weight:600;color:var(--text-secondary);cursor:pointer;border-bottom:3px solid transparent;margin-bottom:-2px;border-radius:8px 8px 0 0;transition:all 0.15s}
.tab-btn:hover{background:var(--bg-hover);color:var(--text-primary)}
.tab-btn.active{color:var(--accent);border-bottom-color:var(--accent);background:var(--accent-bg)}
.tab-badge{display:inline-flex;align-items:center;justify-content:center;width:20px;height:20px;border-radius:50%;font-size:11px;font-weight:700;margin-left:6px;background:var(--bg-thead);color:var(--text-secondary)}
.tab-btn.active .tab-badge{background:var(--accent);color:#fff}
.tab-panel{display:none}.tab-panel.active{display:block}
.scan-panel{background:var(--bg-panel);border-radius:14px;box-shadow:0 2px 8px rgba(0,0,0,0.18);padding:20px 24px;margin-bottom:16px}
.scan-panel h3{font-size:15px;font-weight:700;color:var(--text-primary);margin-bottom:14px}
.scan-row{display:flex;flex-wrap:wrap;gap:10px;align-items:flex-end}
.scan-field{display:flex;flex-direction:column;gap:4px}
.scan-field label{font-size:12px;font-weight:600;color:var(--text-secondary);text-transform:uppercase;letter-spacing:0.04em}
.scan-field input,.scan-field select{padding:9px 12px;border:1px solid var(--border-input);border-radius:8px;font-size:14px;color:var(--text-primary);background:var(--bg-input);outline:none;min-width:150px}
.scan-field input:focus,.scan-field select:focus{border-color:var(--accent)}
.scan-submit{padding:10px 20px;background:var(--accent);color:#fff;border:none;border-radius:8px;font-size:14px;font-weight:700;cursor:pointer;align-self:flex-end}
.filter-bar{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:16px;align-items:center}
.filter-select{padding:9px 13px;border:1px solid var(--border-input);border-radius:8px;font-size:14px;color:var(--text-primary);background:var(--bg-input);outline:none;cursor:pointer}
.filter-select:focus{border-color:var(--accent)}
.filter-toggle{padding:9px 13px;border-radius:8px;font-size:14px;cursor:pointer;text-decoration:none;white-space:nowrap;border:1px solid var(--border-input)}
.filter-toggle-on{background:var(--accent);color:#fff;border-color:var(--accent)}
.filter-toggle-off{background:var(--bg-panel);color:var(--text-primary)}
.clear-link{padding:9px 13px;border-radius:8px;font-size:13px;font-weight:600;color:var(--text-secondary);text-decoration:none;border:1px solid var(--border-input);background:var(--bg-panel);white-space:nowrap}
.clear-link:hover{background:var(--bg-hover)}
.btn-row-del{padding:4px 10px;background:transparent;color:#c4314b;border:1px solid #c4314b;border-radius:6px;font-size:12px;font-weight:700;cursor:pointer}
.btn-row-del:hover{background:#c4314b;color:#fff}
.row-checkbox{width:16px;height:16px;cursor:pointer;accent-color:var(--accent)}
.bulk-bar{position:fixed;bottom:0;left:0;right:0;background:var(--bg-topbar);border-top:1px solid var(--border);padding:14px 28px;display:none;align-items:center;gap:14px;z-index:100;box-shadow:0 -2px 12px rgba(0,0,0,0.15)}
.bulk-count{font-size:14px;font-weight:600;color:var(--text-primary);white-space:nowrap}
.bulk-input{flex:1;max-width:300px;padding:9px 13px;border:1px solid var(--border-input);border-radius:8px;font-size:14px;color:var(--text-primary);background:var(--bg-input);outline:none}
.bulk-input:focus{border-color:var(--accent)}
.bulk-apply{padding:10px 22px;background:var(--accent);color:#fff;border:none;border-radius:8px;font-size:14px;font-weight:700;cursor:pointer;white-space:nowrap}
.bulk-label{font-size:13px;font-weight:600;color:var(--text-secondary);white-space:nowrap}
</style>
</head>
<body>
<div class="page">
  <div style="padding:16px 28px 0;">
    <div class="scan-panel">
      <h3>Scan Device</h3>
      <form method="post" action="/ReturnDevices/Scan" class="scan-row">
        <div class="scan-field">
          <label>Serial Number</label>
          <input type="text" name="serialNumber" placeholder="Scan or type serial…" required />
        </div>
        <button type="submit" class="scan-submit">Scan</button>
      </form>
    </div>
  </div>

  <div class="content">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
      <div style="display:flex;gap:4px">
        <button class="tab-btn active" id="btn-active">Active <span class="tab-badge">@Model.Count</span></button>
        <button class="tab-btn" id="btn-collected">Collected <span class="tab-badge">@collectedDevices.Count</span></button>
      </div>
      <a href="/ReturnDevices/Create" class="btn btn-primary">+ Add Device</a>
    </div>




    <div class="tab-panel active" id="tab-active">
    <form method="get" action="/ReturnDevices">
      <div class="search-form">
        <input class="search-input" name="searchQuery" type="text" placeholder="Search by serial, RITM, work order…" value="@searchQuery" />
        <button type="submit" class="search-btn">Search</button>
      </div>
      <div class="filter-bar">
        <select name="statusFilter" class="filter-select" onchange="this.form.submit()">
          <option value="">All Statuses</option>
          <option value="PendingPickup" selected="@(statusFilter == "PendingPickup" ? "selected" : null)">Pending Pickup</option>
          <option value="PickedUp" selected="@(statusFilter == "PickedUp" ? "selected" : null)">Picked Up</option>
        </select>
        <select name="locationFilter" class="filter-select" onchange="this.form.submit()">
          <option value="">All Locations</option>
          @foreach (var loc in allLocations)
          {
            <option value="@loc" selected="@(locationFilter == loc ? "selected" : null)">@loc</option>
          }
        </select>
        <select name="deviceTypeFilter" class="filter-select" onchange="this.form.submit()">
          <option value="">All Types</option>
          @foreach (var t in allDeviceTypes)
          {
            <option value="@t" selected="@(deviceTypeFilter == t ? "selected" : null)">@t</option>
          }
        </select>
        <a href="?hasWorkOrder=@(!hasWorkOrder)&searchQuery=@Uri.EscapeDataString(searchQuery ?? "")&statusFilter=@Uri.EscapeDataString(statusFilter ?? "")&locationFilter=@Uri.EscapeDataString(locationFilter ?? "")&deviceTypeFilter=@Uri.EscapeDataString(deviceTypeFilter ?? "")"
           class="filter-toggle @(hasWorkOrder ? "filter-toggle-on" : "filter-toggle-off")">
          Has Work Order
        </a>
        @if (anyFilter)
        {
          <a href="/ReturnDevices" class="clear-link">&#x2715; Clear Filters</a>
        }
      </div>
    </form>

    <form id="bulkForm" method="post" action="/ReturnDevices/BulkUpdateWorkOrder">
      <div class="panel">
        <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th><input type="checkbox" id="selectAll" class="row-checkbox" title="Select all" /></th>
              <th>#</th>
              <th>Serial Number</th>
              <th>Type</th>
              <th>RITM</th>
              <th>Date</th>
              <th>Device Location</th>
              <th>Status</th>
              <th>Work Order</th>
              <th>Pickup Status</th>
              <th>Location</th>
              <th>KID</th>
              <th>User Address</th>
              <th>Charger</th>
              <th>Power Cable</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            @if (!Model.Any())
            {
              <tr class="empty"><td colspan="14">No return devices found.@(anyFilter ? " Try clearing the filters." : "")</td></tr>
            }
            else
            {
              @for (int i = 0; i < Model.Count; i++)
              {
                var d = Model[i];
                var statusClass = d.Status == LaptopTracker.Models.ReturnDeviceStatus.PendingPickup ? "b-pending" : "b-pickedup";
                var locClass    = d.DeviceLocation == "In Transit" ? "b-intransit" : "b-inwic";
                string ChargerLabel(bool? v) => v == null ? "—" : v == true ? "✓ Yes" : "✗ No";
                string ChargerClass(bool? v) => v == null ? "" : v == true ? "badge b-yes" : "badge b-no";
                <tr>
                  <td><input type="checkbox" name="ids" value="@d.Id" class="row-check row-checkbox" /></td>
                  <td class="muted">@(i + 1)</td>
                  <td><a class="link" href="/ReturnDevices/Edit/@d.Id">@d.SerialNumber</a></td>
                  <td>@d.DeviceType</td>
                  <td>@d.RITM</td>
                  <td>@d.Date.ToString("dd/MM/yyyy")</td>
                  <td><span class="badge @locClass">@d.DeviceLocation</span></td>
                  <td><span class="badge @statusClass">@(d.Status == LaptopTracker.Models.ReturnDeviceStatus.PendingPickup ? "Pending Pickup" : "Picked Up")</span></td>
                  <td class="muted">@(string.IsNullOrWhiteSpace(d.WorkOrder) ? "—" : d.WorkOrder)</td>
                  <td class="muted">@(string.IsNullOrWhiteSpace(d.PickupStatus) ? "—" : d.PickupStatus)</td>
                  <td class="muted">@(string.IsNullOrWhiteSpace(d.Location) ? "—" : d.Location)</td>
                  <td class="muted">@(string.IsNullOrWhiteSpace(d.KID) ? "—" : d.KID)</td>
                  <td class="muted">@(string.IsNullOrWhiteSpace(d.UserAddress) ? "—" : d.UserAddress)</td>
                  <td>@if (d.ChargerReturned != null) { <span class="@ChargerClass(d.ChargerReturned)">@ChargerLabel(d.ChargerReturned)</span> } else { <span class="muted">—</span> }</td>
                  <td>@if (d.PowerCableReturned != null) { <span class="@ChargerClass(d.PowerCableReturned)">@ChargerLabel(d.PowerCableReturned)</span> } else { <span class="muted">—</span> }</td>
                  <td style="white-space:nowrap">
                    <a class="link" href="/ReturnDevices/Edit/@d.Id">Edit</a>
                    &nbsp;
                    <button type="button" class="btn-row-del" onclick="deleteDevice(@d.Id,'@Html.Raw(d.SerialNumber.Replace("'","\\'"  ))')">&#x1F5D1; Delete</button>
                  </td>
                </tr>
              }
            }
          </tbody>
        </table>
        </div>
      </div>

      <!-- Bulk action bar -->
      <div class="bulk-bar" id="bulkBar">
        <span class="bulk-count" id="bulkCount">0 items selected</span>
        <span class="bulk-label">Set Work Order:</span>
        <input type="text" name="workOrder" id="bulkWorkOrder" class="bulk-input" placeholder="Work Order number…" />
        <button type="button" class="bulk-apply" onclick="applyBulkWorkOrder()">Apply to Selected</button>
        <button type="button" class="bulk-apply" style="background:var(--bg-panel);color:var(--accent);border:1px solid var(--accent);" onclick="editSelected()">Edit Selected</button>
        <button type="button" class="bulk-apply" style="background:#1a7f37;" onclick="handOverSelected()">Hand Over Devices</button>
        <button type="button" class="bulk-apply" style="background:#0369a1;" onclick="exportSelected()">&#x2B07; Export</button>
        <button type="button" class="bulk-apply" style="background:#0f6c75;" onclick="copySelectedRitmSerial()">&#x1F4CB; Copy</button>
      </div>
    </form>
  </div>

  <div class="tab-panel" id="tab-collected">
  <div class="panel"><div class="table-scroll"><table>
<thead><tr><th>#</th><th>Serial Number</th><th>Type</th><th>RITM</th><th>Date</th><th>Location</th><th>Work Order</th><th>Charger</th><th>Cable</th><th></th></tr></thead>
<tbody>
@if (!collectedDevices.Any()) {
<tr class="empty"><td colspan="10">No collected devices.</td></tr>
} else {
@for (int i = 0; i < collectedDevices.Count; i++) {
var d = collectedDevices[i];
<tr>
<td class="muted">@(i+1)</td>
<td><a class="link" href="/ReturnDevices/Edit/@d.Id">@d.SerialNumber</a></td>
<td class="muted">@d.DeviceType</td>
<td class="muted">@d.RITM</td>
<td class="muted">@d.Date.ToString("dd.MM.yyyy")</td>
<td class="muted">@(d.Location ?? d.DeviceLocation)</td>
<td class="muted">@(string.IsNullOrWhiteSpace(d.WorkOrder) ? "-" : d.WorkOrder)</td>
<td>@if(d.ChargerReturned==true){<span class="badge b-yes">YES</span>}else{<span class="badge b-no">NO</span>}</td>
<td>@if(d.PowerCableReturned==true){<span class="badge b-yes">YES</span>}else{<span class="badge b-no">NO</span>}</td>
<td><a class="link" href="/ReturnDevices/Edit/@d.Id">Edit</a></td>
</tr>
}
}
</tbody>
</table></div></div>
  </div>
</div>
<script src="/js/theme.js"></script>
<script>
var selectAll = document.getElementById('selectAll');
var bulkBar   = document.getElementById('bulkBar');
var bulkCount = document.getElementById('bulkCount');

function getChecked() { return document.querySelectorAll('.row-check:checked'); }
function getAllChecks() { return document.querySelectorAll('.row-check'); }

function updateBulkBar() {
  var n = getChecked().length;
  var total = getAllChecks().length;
  bulkBar.style.display = n > 0 ? 'flex' : 'none';
  bulkCount.textContent = n + ' item' + (n === 1 ? '' : 's') + ' selected';
  selectAll.indeterminate = n > 0 && n < total;
  selectAll.checked = total > 0 && n === total;
}

selectAll.addEventListener('change', function() {
  getAllChecks().forEach(function(c) { c.checked = selectAll.checked; });
  updateBulkBar();
});

getAllChecks().forEach(function(c) { c.addEventListener('change', updateBulkBar); });

function applyBulkWorkOrder() {
  var n = getChecked().length;
  var wo = document.getElementById('bulkWorkOrder').value.trim();
  if (n === 0) { alert('No devices selected.'); return; }
  if (!wo) { alert('Please enter a Work Order number.'); return; }
  if (!confirm('Apply Work Order "' + wo + '" to ' + n + ' device' + (n === 1 ? '' : 's') + '?')) return;
  document.getElementById('bulkForm').submit();
}
function editSelected() {
  var checks = getChecked();
  if (checks.length === 0) { alert('No devices selected.'); return; }
  var url = '/ReturnDevices/BulkEdit?' + Array.from(checks).map(function(c) { return 'ids=' + encodeURIComponent(c.value); }).join('&');
  window.location.href = url;
}
function deleteDevice(id, serial) {
  if (!confirm('Delete ' + serial + '? This cannot be undone.')) return;
  var f = document.createElement('form');
  f.method = 'post';
  f.action = '/ReturnDevices/Delete/' + id;
  document.body.appendChild(f);
  f.submit();
}
function copySelectedRitmSerial() {
  var checks = getChecked();
  if (checks.length === 0) { alert("No devices selected."); return; }
  var rows = Array.from(checks).map(function(c) {
    var row = c.closest("tr");
    var cells = row.querySelectorAll("td");
    var serial = cells[2] ? cells[2].innerText.trim() : "";
    var ritm = cells[4] ? cells[4].innerText.trim() : "";
    return ritm + "  " + serial;
  });
  var text = rows.join("\n");
  navigator.clipboard.writeText(text).then(function() {
    alert("Copied!\n\n" + text);
  });
}
function exportSelected() {
  var checks = getChecked();
  if (checks.length === 0) { alert("No devices selected."); return; }
  var url = "/Export/ExportSelected?" + Array.from(checks).map(function(c) { return "ids=" + encodeURIComponent(c.value); }).join("&");
  window.location.href = url;
}
function handOverSelected() {
  var checks = getChecked();
  if (checks.length === 0) { alert('No devices selected.'); return; }
  var url = '/Handovers/Create?source=ReturnDevices&' + Array.from(checks).map(function(c) { return 'ids=' + encodeURIComponent(c.value); }).join('&');
  window.location.href = url;
}
document.getElementById("btn-active").addEventListener("click",function(){switchTab("active");});
document.getElementById("btn-collected").addEventListener("click",function(){switchTab("collected");});
function switchTab(name){
  document.querySelectorAll(".tab-panel").forEach(function(p){p.classList.remove("active");});
  document.querySelectorAll(".tab-btn").forEach(function(b){b.classList.remove("active");});
  document.getElementById("tab-"+name).classList.add("active");
  document.getElementById("btn-"+name).classList.add("active");
}
</script>
</div>
</body>
</html>

























