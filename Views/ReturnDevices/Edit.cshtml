@model LaptopTracker.Models.ReturnDevice
@using LaptopTracker.Helpers
@{
    ViewData["Title"] = "Edit Return Device";
    var deviceTypes = new[] { "Lenovo", "HP", "Dell", "Apple iPad" };
    var eonLocations = LocationList.Locations.OrderBy(l => l).ToList();
    var curLoc = Model.Location ?? "";
    var locInList = eonLocations.Contains(curLoc);
    var showOther = !locInList && curLoc != "";
}
@section Styles {
<style>
.back{padding:9px 18px;border-radius:10px;font-size:14px;font-weight:700;text-decoration:none;border:1px solid var(--accent);color:var(--accent);background:transparent;display:inline-block;margin-bottom:16px}
.content{padding:24px 28px 0}
.page-title{font-size:20px;font-weight:700;margin-bottom:20px;color:var(--text-primary)}
.form-card{background:var(--bg-panel);border-radius:14px;box-shadow:0 2px 8px rgba(0,0,0,0.18);padding:28px 32px;max-width:860px}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px 24px}
.form-full{grid-column:1/-1}
.fg{display:flex;flex-direction:column;gap:6px}
.fg label{font-size:13px;font-weight:600;color:var(--text-primary)}
.fg input,.fg select{padding:10px 13px;border:1px solid var(--border-input);border-radius:8px;font-size:14px;color:var(--text-primary);background:var(--bg-input);font-family:inherit;outline:none}
.fg input:focus,.fg select:focus{border-color:var(--accent)}
.fg .hint{font-size:12px;color:var(--text-muted)}
.form-actions{display:flex;gap:12px;align-items:center;padding-top:8px;flex-wrap:wrap}
.btn-submit{padding:11px 24px;background:var(--accent);color:#fff;border:none;border-radius:10px;font-size:14px;font-weight:700;cursor:pointer}
.btn-cancel{padding:11px 20px;background:transparent;color:var(--text-secondary);border:1px solid var(--border-input);border-radius:10px;font-size:14px;font-weight:600;text-decoration:none;display:inline-block}
.btn-delete{padding:11px 20px;background:#c4314b;color:#fff;border:none;border-radius:10px;font-size:14px;font-weight:700;cursor:pointer;margin-left:auto}
.section-divider{grid-column:1/-1;border-top:1px solid var(--border);margin-top:4px;padding-top:4px}
.section-label-sm{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:var(--text-secondary);margin-bottom:-8px}
</style>
}
  <div class="content">
    <a href="/ReturnDevices" class="back">&larr; Back</a>
    <div class="page-title">Edit Return Device — @Model.SerialNumber</div>
    <div class="form-card">
      <form method="post" action="/ReturnDevices/Edit/@Model.Id" enctype="multipart/form-data">
        <input type="hidden" name="Id" value="@Model.Id" />
        <input type="hidden" name="DeviceStateType" value="Return" />
        <div class="form-grid">

          <div class="fg">
            <label>Serial Number *</label>
            <input name="SerialNumber" type="text" value="@Model.SerialNumber" required />
          </div>

          <div class="fg">
            <label>Device Type</label>
            <select name="DeviceType">
              @foreach (var t in deviceTypes)
              {
                <option value="@t" selected="@(Model.DeviceType == t ? "selected" : null)">@t</option>
              }
            </select>
          </div>

          <div class="fg">
            <label>RITM *</label>
            <input name="RITM" type="text" value="@Model.RITM" required />
          </div>

          <div class="fg">
            <label>Date</label>
            <input name="Date" type="date" value="@Model.Date.ToString("yyyy-MM-dd")" />
          </div>

          <div class="fg">
            <label>Device Location</label>
            <select name="DeviceLocation">
              @foreach (var loc in new[] { "In WIC", "In Transit" })
              {
                <option value="@loc" selected="@(Model.DeviceLocation == loc ? "selected" : null)">@loc</option>
              }
            </select>
          </div>

          <div class="fg">
            <label>Status</label>
            <select name="Status">
              <option value="PendingPickup" selected="@(Model.Status == LaptopTracker.Models.ReturnDeviceStatus.PendingPickup ? "selected" : null)">Pending Pickup</option>
              <option value="PickedUp" selected="@(Model.Status == LaptopTracker.Models.ReturnDeviceStatus.PickedUp ? "selected" : null)">Picked Up</option>
            </select>
          </div>

          <div class="fg">
            <label>Work Order <span class="hint">(optional)</span></label>
            <input name="WorkOrder" type="text" value="@Model.WorkOrder" />
          </div>

          <div class="fg">
            <label>Pickup Status <span class="hint">(optional)</span></label>
            <input name="PickupStatus" type="text" value="@Model.PickupStatus" />
          </div>
          <div class="fg">
            <label>KID <span class="hint">(who uses it)</span></label>
            <input name="KID" type="text" value="@Model.KID" placeholder="e.g. A57253" />
          </div>
          <div class="fg">
            <label>User Address <span class="hint">(where it is)</span></label>
            <input name="UserAddress" type="text" value="@Model.UserAddress" placeholder="e.g. Saarbrücken, Hohenzollernstraße 75 (66117)" />
          </div>

          <!-- Accessories returned section -->
          <div class="section-divider">
            <div class="section-label-sm">Accessories Returned</div>
          </div>

          <div class="fg">
            <label>Charger returned? (Ladegerät zurückgegeben?)</label>
            <select name="ChargerReturned">
              <option value="" selected="@(Model.ChargerReturned == null ? "selected" : null)">— Not specified —</option>
              <option value="true" selected="@(Model.ChargerReturned == true ? "selected" : null)">Yes</option>
              <option value="false" selected="@(Model.ChargerReturned == false ? "selected" : null)">No</option>
            </select>
          </div>

          <div class="fg">
            <label>Power cable returned? (Netzkabel zurückgegeben?)</label>
            <select name="PowerCableReturned">
              <option value="" selected="@(Model.PowerCableReturned == null ? "selected" : null)">— Not specified —</option>
              <option value="true" selected="@(Model.PowerCableReturned == true ? "selected" : null)">Yes</option>
              <option value="false" selected="@(Model.PowerCableReturned == false ? "selected" : null)">No</option>
            </select>
          </div>

          <div class="fg form-full">
            <label>Location <span class="hint">(optional)</span></label>
            <select id="locSelect" onchange="onLocChange(this)">
              <option value="">— Select location —</option>
              @foreach (var l in eonLocations)
              {
                <option value="@l" selected="@(locInList && curLoc == l ? "selected" : null)">@l</option>
              }
              <option value="__other__" selected="@(showOther ? "selected" : null)">Other (type below)</option>
            </select>
            <input id="locCustom" type="text" placeholder="Type custom location…"
                   style="margin-top:6px;@(showOther ? "" : "display:none;")"
                   value="@(showOther ? curLoc : "")"
                   oninput="document.getElementById('locHidden').value=this.value" />
            <input type="hidden" id="locHidden" name="Location" value="@curLoc" />
          </div>

          <!-- Inspection section -->
          <div class="section-divider">
            <div class="section-label-sm">Inspection / Zustandsprüfung</div>
          </div>

          <div class="fg">
            <label>Damage Status <span class="hint">(optional)</span></label>
            <input name="DamageStatus" type="text" value="@Model.DamageStatus" placeholder="e.g. Screen cracked" />
          </div>

          <div class="fg">
            <label>Acknowledgement</label>
            <select name="Acknowledgement">
              <option value="" selected="@(string.IsNullOrEmpty(Model.Acknowledgement) ? "selected" : null)">— Not specified —</option>
              <option value="Signed by user" selected="@(Model.Acknowledgement == "Signed by user" ? "selected" : null)">Signed by user</option>
              <option value="Signed by manager" selected="@(Model.Acknowledgement == "Signed by manager" ? "selected" : null)">Signed by manager</option>
              <option value="Declined" selected="@(Model.Acknowledgement == "Declined" ? "selected" : null)">Declined</option>
            </select>
          </div>

          <div class="fg">
            <label>Customer Induced Damage?</label>
            <select name="IsCustomerInducedDamage">
              <option value="false" selected="@(!Model.IsCustomerInducedDamage ? "selected" : null)">No</option>
              <option value="true" selected="@(Model.IsCustomerInducedDamage ? "selected" : null)">Yes</option>
            </select>
          </div>

          <div class="fg">
            <label>Battery Swollen?</label>
            <select name="IsBatterySwollen">
              <option value="false" selected="@(!Model.IsBatterySwollen ? "selected" : null)">No</option>
              <option value="true" selected="@(Model.IsBatterySwollen ? "selected" : null)">Yes</option>
            </select>
          </div>

          <!-- Photos section -->
          <div class="section-divider">
            <div class="section-label-sm">Photos / Fotos</div>
          </div>

          <div class="fg form-full">
            <label>Upload Photos <span class="hint">(jpg/png, max 10 MB each)</span></label>
            <input name="photos" type="file" accept=".jpg,.jpeg,.png" multiple />
          </div>

          @{
            var regularPhotos = Model.Photos?.Where(p => !p.IsSignature).ToList() ?? new();
            var signatures    = Model.Photos?.Where(p => p.IsSignature).ToList() ?? new();
          }

          @if (regularPhotos.Count > 0)
          {
            <div class="form-full" style="display:flex;flex-wrap:wrap;gap:12px;margin-top:4px;">
              @foreach (var photo in regularPhotos)
              {
                <div style="position:relative;display:inline-block;" id="photo-@photo.Id">
                  <a href="@photo.FilePath" download="@(photo.OriginalFileName ?? "photo")">
                    <img src="@photo.FilePath" alt="@photo.OriginalFileName"
                         style="width:120px;height:90px;object-fit:cover;border-radius:8px;border:1px solid var(--border-input);display:block;" />
                  </a>
                  <button type="button" onclick="deletePhoto(@photo.Id)"
                          style="position:absolute;top:4px;right:4px;background:#c4314b;color:#fff;border:none;border-radius:50%;width:22px;height:22px;font-size:12px;line-height:1;cursor:pointer;padding:0;">✕</button>
                </div>
              }
            </div>
          }

          <!-- Signature section -->
          <div class="section-divider">
            <div class="section-label-sm">Signature / Unterschrift</div>
          </div>

          @if (signatures.Count > 0)
          {
            <div class="form-full" style="display:flex;flex-wrap:wrap;gap:12px;margin-bottom:12px;">
              @foreach (var sig in signatures)
              {
                <div style="position:relative;display:inline-block;" id="photo-@sig.Id">
                  <a href="@sig.FilePath" download="signature.png" title="Download signature">
                    <img src="@sig.FilePath" alt="Signature"
                         style="height:80px;max-width:320px;object-fit:contain;border-radius:8px;border:2px solid var(--accent);background:#fff;display:block;padding:4px;" />
                  </a>
                  <span style="font-size:11px;color:var(--text-muted);display:block;margin-top:2px;">@sig.UploadedAt.ToString("dd.MM.yyyy HH:mm")</span>
                  <button type="button" onclick="deletePhoto(@sig.Id)"
                          style="position:absolute;top:4px;right:4px;background:#c4314b;color:#fff;border:none;border-radius:50%;width:22px;height:22px;font-size:12px;line-height:1;cursor:pointer;padding:0;">✕</button>
                </div>
              }
            </div>
          }

          <div class="fg form-full">
            <label>Draw new signature <span class="hint">(finger/stylus/mouse — draw here, then Save)</span></label>
            <div style="position:relative;display:inline-block;width:100%;">
              <canvas id="sigPad"
                      style="display:block;width:100%;height:200px;border:2px dashed var(--border-input);border-radius:8px;background:#fff;touch-action:none;cursor:crosshair;box-sizing:border-box;"></canvas>
              <button type="button" id="sigClear"
                      style="position:absolute;top:8px;right:8px;padding:5px 12px;background:var(--bg-panel);border:1px solid var(--border-input);border-radius:6px;font-size:12px;font-weight:600;color:var(--text-secondary);cursor:pointer;">Clear</button>
            </div>
            <span class="hint" style="margin-top:4px;">Leave blank to keep existing signature(s). Draw only if a new signature is needed.</span>
            <input type="hidden" name="signatureData" id="sigData" />
          </div>

          <div class="form-actions form-full">
            <button type="submit" class="btn-submit">Save Changes</button>
            <a href="/ReturnDevices" class="btn-cancel">Cancel</a>
            <button type="button" class="btn-delete" onclick="deleteDevice()">&#x1F5D1; Delete Device</button>
          </div>

        </div>
      </form>

      <form id="deleteForm" method="post" action="/ReturnDevices/Delete/@Model.Id" style="display:none;"></form>
    </div>
  </div>
@section Scripts {
<script>
function onLocChange(sel) {
  var c = document.getElementById('locCustom');
  var h = document.getElementById('locHidden');
  if (sel.value === '__other__') {
    c.style.display = ''; c.value = ''; h.value = ''; c.focus();
  } else {
    c.style.display = 'none'; h.value = sel.value;
  }
}
function deleteDevice() {
  if (confirm('Delete device @Html.Raw(Model.SerialNumber.Replace("'", "\\'"))? This cannot be undone.')) {
    document.getElementById('deleteForm').submit();
  }
}
async function deletePhoto(photoId) {
  if (!confirm('Delete this photo? This cannot be undone.')) return;
  const resp = await fetch('/ReturnDevices/DeletePhoto/' + photoId, { method: 'POST', headers: { 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '' } });
  if (resp.ok) {
    var el = document.getElementById('photo-' + photoId);
    if (el) el.remove();
  } else {
    alert('Failed to delete photo.');
  }
}

(function () {
  var canvas = document.getElementById('sigPad');
  var ctx = canvas.getContext('2d');
  var drawing = false;
  var hasDrawn = false;

  function resize() {
    var rect = canvas.getBoundingClientRect();
    var dpr = window.devicePixelRatio || 1;
    // preserve existing drawing during resize
    var img = canvas.toDataURL();
    canvas.width  = Math.round(rect.width  * dpr);
    canvas.height = Math.round(rect.height * dpr);
    ctx.scale(dpr, dpr);
    ctx.lineCap   = 'round';
    ctx.lineJoin  = 'round';
    ctx.lineWidth = 2;
    ctx.strokeStyle = '#000';
    if (hasDrawn) {
      var i = new Image();
      i.onload = function() { ctx.drawImage(i, 0, 0, rect.width, rect.height); };
      i.src = img;
    }
  }
  resize();
  window.addEventListener('resize', resize);

  function pos(e) {
    var r = canvas.getBoundingClientRect();
    if (e.touches) {
      return { x: e.touches[0].clientX - r.left, y: e.touches[0].clientY - r.top };
    }
    return { x: e.clientX - r.left, y: e.clientY - r.top };
  }

  canvas.addEventListener('pointerdown', function(e) {
    e.preventDefault();
    drawing = true;
    var p = pos(e);
    ctx.beginPath();
    ctx.moveTo(p.x, p.y);
    canvas.setPointerCapture(e.pointerId);
  });

  canvas.addEventListener('pointermove', function(e) {
    if (!drawing) return;
    e.preventDefault();
    var p = pos(e);
    ctx.lineTo(p.x, p.y);
    ctx.stroke();
    hasDrawn = true;
  });

  canvas.addEventListener('pointerup',     function(e) { drawing = false; });
  canvas.addEventListener('pointercancel', function(e) { drawing = false; });

  document.getElementById('sigClear').addEventListener('click', function() {
    var r = canvas.getBoundingClientRect();
    ctx.clearRect(0, 0, r.width, r.height);
    hasDrawn = false;
    document.getElementById('sigData').value = '';
  });

  // On submit, serialize canvas only if the user actually drew something
  canvas.closest('form').addEventListener('submit', function() {
    if (hasDrawn) {
      document.getElementById('sigData').value = canvas.toDataURL('image/png');
    }
  });
})();
</script>
}

